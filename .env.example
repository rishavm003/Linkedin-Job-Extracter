# ════════════════════════════════════════════════════════
# JobExtractor — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jobuser:jobpass@localhost:5432/jobextractor

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── Adzuna API ────────────────────────────────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Apyhud API ────────────────────────────────────────────────────────────────
APYHUB_API_KEY=your_apyhub_key

# ── RapidAPI ──────────────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key

# ── Arbeitnow API ─────────────────────────────────────────────────────────────
ARBEITNOW_API_URL=https://arbeitnow.com/api/job-board-api

# ── Findwork API ──────────────────────────────────────────────────────────────
FINDWORK_API_KEY=

# ── Jooble API ────────────────────────────────────────────────────────────────
JOOBLE_API_KEY=

# ── The Muse API ──────────────────────────────────────────────────────────────
THE_MUSE_API_KEY=

# ── Reed API ──────────────────────────────────────────────────────────────────
REED_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Frontend URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Scraper settings ─────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
MAX_JOBS_PER_PORTAL=200
SCRAPE_INTERVAL_HOURS=6

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
