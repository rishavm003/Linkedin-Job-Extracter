# Copy this file to .env and fill in your values
# Never commit .env to git!

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (matches docker-compose defaults)
DATABASE_URL=postgresql://jobuser:jobpass@localhost:5432/jobextractor

# Supabase (production free tier)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# Upstash (free tier): REDIS_URL=rediss://:[password]@[host]:6379

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
# Bonsai free tier: ELASTICSEARCH_URL=https://[credentials]@[host].bonsaisearch.net

# ── Scraper settings ─────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
MAX_JOBS_PER_PORTAL=200
SCRAPE_INTERVAL_HOURS=6

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
